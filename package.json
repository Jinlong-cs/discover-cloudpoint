{
  "name": "discover-pointcloud",
  "version": "0.1.0",
  "description": "DiscoverStereo point cloud comparison desktop app",
  "main": "electron/main.js",
  "author": "DiscoverStereo Contributors",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "app": "electron .",
    "dist:mac": "electron-builder --mac dir"
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.discover.pointcloudcompare",
    "productName": "Discover PointCloud",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "app.js",
      "styles.css",
      "vendor/**/*",
      "electron/**/*",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir"
      ]
    }
  }
}
